{
  "name": "salarize",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@react-oauth/google": "^0.12.1",
    "@supabase/supabase-js": "^2.90.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^2.10.0",
    "web-vitals": "^5.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/features",
      "/pricing",
      "/demo",
      "/legal",
      "/privacy",
      "/terms",
      "/cookies"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "skipThirdPartyRequests": true,
    "headless": true,
    "viewport": {
      "width": 1440,
      "height": 900
    },
    "crawl": false
  }
}
